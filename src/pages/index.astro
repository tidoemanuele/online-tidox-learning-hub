---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const episodes = await getCollection('episodes');
const sorted = episodes.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latest = sorted[0];

// If only one episode, redirect to it
if (sorted.length === 1) {
  return Astro.redirect(`/daily/${latest.data.date}`);
}
---

<Base title="Archive">
  <h1 class="text-[28px] font-bold font-[family-name:var(--font-display)] text-navy mb-6">
    Episodes
  </h1>

  <div class="space-y-0">
    {sorted.map((ep) => (
      <a
        href={`/daily/${ep.data.date}`}
        class="flex items-center justify-between py-4 border-b border-divider hover:bg-light-bg/50 transition-colors -mx-3 px-3 rounded"
      >
        <div class="flex items-center gap-4">
          <span class="text-[12px] font-[family-name:var(--font-mono)] text-gray w-24 flex-shrink-0">
            {ep.data.date}
          </span>
          <span class="text-[15px] text-near-black">
            {ep.data.subtitle}
          </span>
        </div>
        <span class="text-[11px] bg-light-bg text-gray px-2 py-0.5 rounded flex-shrink-0">
          {ep.data.insights.length} insights
        </span>
      </a>
    ))}
  </div>
</Base>
