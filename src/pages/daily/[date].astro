---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import Base from '../../layouts/Base.astro';
import { VideoPlayer } from '../../components/VideoPlayer';
import { TrendingReposList } from '../../components/TrendingReposList';
import { getCollection } from 'astro:content';
import { resolveInsightLink } from '../../lib/hub-episode-utils';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((ep) => ({
    params: { date: ep.data.date },
    props: { episode: ep },
  }));
}

const { episode } = Astro.props;
const ep = episode.data;

/** Pre-rendered MP4 must live at public/video/{date}.mp4 to be deployed with the site. */
const mp4Path = join(process.cwd(), 'public', 'video', `${ep.date}.mp4`);
const hasRenderedMp4 = existsSync(mp4Path);

/** Audio for Remotion Player: explicit briefAudioUrl, then on-disk brief/narration, then podcastUrl. */
const audioDir = join(process.cwd(), 'public', 'audio', ep.date);
/** Prefer MP3 (widest decode support in Chromium / Remotion Html5Audio); then AAC m4a, then WAV. */
const localBriefNames = [
  'brief.mp3',
  'brief.m4a',
  'brief.wav',
  'narration.mp3',
  'narration.m4a',
  'narration.wav',
];
let localBriefUrl: string | undefined;
for (const name of localBriefNames) {
  if (existsSync(join(audioDir, name))) {
    localBriefUrl = `/audio/${ep.date}/${name}`;
    break;
  }
}
const resolvedBriefAudio =
  ep.audio?.briefAudioUrl?.trim() || localBriefUrl || ep.audio?.podcastUrl?.trim() || undefined;
const episodeForRemotion = {
  ...ep,
  audio: resolvedBriefAudio
    ? { ...(ep.audio ?? {}), briefAudioUrl: resolvedBriefAudio }
    : ep.audio,
};

// Find prev/next episodes for navigation
const allEpisodes = await getCollection('episodes');
const sorted = allEpisodes.sort((a, b) => a.data.date.localeCompare(b.data.date));
const currentIndex = sorted.findIndex(e => e.data.date === ep.date);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const insightTextsForTrendingFallback = ep.insights.map((i) => i.text);
---

<Base title={`Episode ${ep.episodeNumber} · ${ep.date}`} description={ep.subtitle}>
  <article>
    <!-- Episode meta -->
    <div class="mb-2">
      <span class="inline-block text-[12px] font-[family-name:var(--font-mono)] text-gray bg-light-bg px-2.5 py-1 rounded">
        EPISODE {ep.episodeNumber} · {ep.date.replace(/-/g, '.')}
      </span>
    </div>

    <!-- Brand label -->
    <p class="text-[11px] font-[family-name:var(--font-mono)] tracking-[1.5px] uppercase text-terracotta mb-3">
      {ep.title}
    </p>

    <!-- Daily editorial headline (the hero text) -->
    <h1 class="text-[28px] md:text-[32px] font-bold font-[family-name:var(--font-display)] text-heading leading-tight mb-6">
      {ep.subtitle}
    </h1>

    <!-- Hero stat -->
    {ep.heroStat && (
      <div class="bg-navy rounded-xl px-6 py-5 mb-6">
        <p class="text-[48px] md:text-[56px] font-bold font-[family-name:var(--font-mono)] text-cream leading-none">
          {ep.heroStat.value}
        </p>
        <p class="text-[14px] text-cream/70 mt-1">
          {ep.heroStat.label}
        </p>
      </div>
    )}

    <!-- Video: pre-rendered MP4 in public/video/ when present; otherwise client-side Remotion (same data as episode JSON) -->
    <div class="rounded-xl overflow-hidden mb-3 bg-void">
      {hasRenderedMp4 ? (
        <video
          class="w-full aspect-video bg-void"
          controls
          playsinline
          preload="metadata"
          aria-label="Daily intelligence brief"
        >
          <source src={`/video/${ep.date}.mp4`} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      ) : (
        <VideoPlayer client:visible episode={episodeForRemotion} />
      )}
    </div>
    <div class="flex justify-between text-[12px] text-gray mb-8">
      <span>Daily intelligence brief · Two-voice podcast with visuals</span>
    </div>

    <!-- Audio player -->
    {ep.audio?.podcastUrl ? (
      <div class="bg-light-bg border border-divider rounded-lg p-4 mb-8" aria-label="Full podcast episode">
        <div class="flex items-center gap-3 mb-3">
          <div class="w-9 h-9 bg-terracotta rounded-full flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-cream ml-0.5" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="5,3 19,12 5,21" />
            </svg>
          </div>
          <div>
            <p class="text-[13px] font-semibold text-near-black">Podcast audio</p>
            <p class="text-[11px] text-gray">Full episode (may differ from brief length)</p>
          </div>
        </div>
        <audio controls preload="metadata" class="w-full" src={ep.audio.podcastUrl}>
          Your browser does not support audio playback.
        </audio>
      </div>
    ) : (
      <!-- Audio hidden when no podcast URL -->
      <Fragment />
    )}

    <!-- Action row -->
    <div class="flex items-center gap-4 text-[12px] text-gray mb-8 pb-8 border-b border-divider">
      <button class="hover:text-cream transition-colors" title="Copy link">Share</button>
      <span class="text-divider">·</span>
      <a href="/feed.xml" class="hover:text-cream transition-colors">RSS</a>
      <span class="text-divider">·</span>
      <span class="text-gray/50">Get daily email (coming soon)</span>
    </div>

    <!-- Two-column: Insights + Trending -->
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr] gap-8">
      <!-- Insights -->
      <section role="feed" aria-label="Today's insights">
        <h2 class="text-[11px] font-bold tracking-[1.5px] uppercase text-terracotta mb-4 pb-2 border-b-2 border-terracotta">
          Today's Insights
        </h2>
        {ep.insights.map((insight) => {
          const link = resolveInsightLink(insight);
          return (
          <article role="article" class="py-4 border-b border-divider last:border-b-0">
            {link?.isDirect ? (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="block group rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta/50"
              >
                <p class="text-[15px] leading-relaxed mb-2 group-hover:text-terracotta transition-colors">{insight.text}</p>
              </a>
            ) : (
              <p class="text-[15px] leading-relaxed mb-2">{insight.text}</p>
            )}
            {link && !link.isDirect && (
              <p class="mb-2">
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[12px] font-semibold text-terracotta hover:underline"
                >
                  {link.label} ↗
                </a>
              </p>
            )}
            <div class="flex gap-1.5 flex-wrap items-center">
              {insight.tags.map((tag) => (
                <span class="text-[11px] px-2 py-0.5 rounded bg-light-bg text-gray">{tag}</span>
              ))}
              {insight.source && (
                <span class="text-[11px] px-2 py-0.5 rounded bg-light-bg text-gray font-[family-name:var(--font-mono)]">
                  {insight.source}
                </span>
              )}
            </div>
          </article>
          );
        })}
      </section>

      <!-- Trending repos -->
      <section aria-label="Trending repositories">
        <h2 class="text-[11px] font-bold tracking-[1.5px] uppercase text-terracotta mb-4 pb-2 border-b-2 border-terracotta">
          Trending Repos
        </h2>
        <TrendingReposList
          client:visible
          repos={ep.trending}
          insightTextsFallback={insightTextsForTrendingFallback}
        />
      </section>
    </div>

    <!-- Episode navigation -->
    <nav class="flex justify-between mt-12 pt-6 border-t border-divider text-[13px]" aria-label="Episode navigation">
      {prev ? (
        <a href={`/daily/${prev.data.date}`} class="text-heading hover:text-terracotta transition-colors">
          &larr; {prev.data.date}
        </a>
      ) : (
        <span class="text-gray/40 italic">This is where it begins.</span>
      )}
      {next ? (
        <a href={`/daily/${next.data.date}`} class="text-heading hover:text-terracotta transition-colors">
          {next.data.date} &rarr;
        </a>
      ) : (
        <span class="text-divider">Tomorrow &rarr;</span>
      )}
    </nav>
  </article>
</Base>
