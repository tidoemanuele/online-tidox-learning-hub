---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Automated daily intelligence — built by a solo developer with AI' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark" />
  <title>{title} — Tidox Learning Hub</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={`${title} — Tidox Learning Hub`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <header class="border-b border-divider">
    <nav class="mx-auto max-w-[960px] px-6 flex h-14 items-center justify-between">
      <a href="/" class="text-lg font-bold font-[family-name:var(--font-display)] text-heading">
        tidox<span class="text-terracotta">.</span>hub
      </a>
      <div class="hidden md:flex items-center gap-5 text-[13px] text-gray">
        <a href="/" class={`${currentPath === '/' || currentPath.startsWith('/daily/') ? 'text-heading' : 'text-gray'} hover:text-heading transition-colors`}>Today</a>
        <a href="/archive" class={`${currentPath === '/archive' || currentPath === '/archive/' ? 'text-heading' : 'text-gray'} hover:text-heading transition-colors`}>Archive</a>
        <a href="/about" class={`${currentPath === '/about' || currentPath === '/about/' ? 'text-heading' : 'text-gray'} hover:text-heading transition-colors`}>About</a>
      </div>
      <!-- Mobile hamburger placeholder -->
      <button type="button" id="mobile-toggle" class="md:hidden p-2 text-gray hover:text-heading" aria-label="Menu">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </nav>
  </header>

  <!-- Content -->
  <main class="flex-1">
    <div class="mx-auto max-w-[960px] px-6 py-8">
      <slot />
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-divider py-6">
    <div class="mx-auto max-w-[960px] px-6 text-center text-[12px] text-gray">
      <p>Tidox Learning Hub · Automated daily intelligence · Built by a solo developer with AI</p>
    </div>
  </footer>
</body>
</html>
